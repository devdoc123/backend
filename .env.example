# ===== Server =====
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ===== Database (Supabase PostgreSQL) =====
# Use the Supabase connection string (Session pooler / direct connection).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_ms
# Set to "true" when connecting to Supabase / managed Postgres that requires SSL
DATABASE_SSL=false

# ===== JWT =====
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=365d

# ===== Redis (Upstash) =====
# Leave empty to use an in-memory cache fallback (single instance only)
REDIS_URL=

# ===== Business defaults =====
# Default grace period (days) applied when a plan does not define one
DEFAULT_GRACE_PERIOD_DAYS=5
# Default country dial code used to normalize phone numbers for wa.me links
DEFAULT_DIAL_CODE=92
# Currency code/symbol used in receipts and reports
CURRENCY=PKR

# ===== Seed user =====
SEED_OWNER_EMAIL=admin@gym.local
SEED_OWNER_PASSWORD=Admin@123456
SEED_OWNER_NAME=Gym Owner
